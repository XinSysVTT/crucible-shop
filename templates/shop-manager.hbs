<div class="crucible-shop-manager-layout">

  <aside class="shop-list-panel">
    <button type="button" class="create-shop" data-action="createShop">
      <i class="fa-solid fa-plus"></i> {{localize "CRUCIBLE_SHOP.NewShop"}}
    </button>
    <ol class="shop-list">
      {{#each shops as |shop|}}
      <li class="shop-list-entry {{#if shop.active}}active{{/if}}" data-shop-id="{{shop.id}}" data-action="selectShop">
        <i class="fa-solid fa-coins"></i>
        <span class="shop-list-name">{{shop.name}}</span>
        <span class="shop-list-mode">{{#if (eq shop.mode "custom")}}{{localize "CRUCIBLE_SHOP.ModeCustomShort"}}{{else}}{{localize "CRUCIBLE_SHOP.ModeDefaultShort"}}{{/if}}</span>
        {{#unless (eq shop.id "default")}}
        <a class="delete-shop" data-action="deleteShop" data-shop-id="{{shop.id}}" data-tooltip="{{localize 'CRUCIBLE_SHOP.DeleteShop'}}">
          <i class="fa-solid fa-trash"></i>
        </a>
        {{/unless}}
      </li>
      {{/each}}
    </ol>
  </aside>

  <section class="shop-detail-panel">
    {{#if selected}}

    <div class="shop-detail-header">
      <div class="form-group">
        <label>{{localize "CRUCIBLE_SHOP.ShopName"}}</label>
        <input type="text" class="shop-name-input" value="{{selected.name}}"/>
      </div>
      <div class="form-group">
        <label>{{localize "CRUCIBLE_SHOP.Stock"}}</label>
        <select class="shop-mode-select" {{#if isDefaultShop}}disabled{{/if}}>
          <option value="default" {{#if (eq selected.mode "default")}}selected{{/if}}>{{localize "CRUCIBLE_SHOP.ModeDefault"}}</option>
          <option value="custom" {{#if (eq selected.mode "custom")}}selected{{/if}}>{{localize "CRUCIBLE_SHOP.ModeCustom"}}</option>
        </select>
      </div>
      <div class="form-group">
        <label data-tooltip="{{localize 'CRUCIBLE_SHOP.BuyRateHint'}}">{{localize "CRUCIBLE_SHOP.BuyRate"}}</label>
        <input type="number" class="shop-buy-rate-input" min="0" max="500" step="5" value="{{selected.buyRate}}"/>
      </div>
      <div class="form-group">
        <label data-tooltip="{{localize 'CRUCIBLE_SHOP.SellRateHint'}}">{{localize "CRUCIBLE_SHOP.SellRate"}}</label>
        <input type="number" class="shop-sell-rate-input" min="0" max="500" step="5" value="{{selected.sellRate}}"/>
      </div>
      <div class="form-group form-group-checkbox">
        <label data-tooltip="{{localize 'CRUCIBLE_SHOP.RequireApprovalHint'}}">{{localize "CRUCIBLE_SHOP.RequireApproval"}}</label>
        <input type="checkbox" class="shop-require-approval-input" {{#if selected.requireApproval}}checked{{/if}}/>
      </div>
      <button type="button" class="preview-shop" data-action="openShop">
        <i class="fa-solid fa-eye"></i> {{localize "CRUCIBLE_SHOP.Preview"}}
      </button>
    </div>

    {{#if (eq selected.mode "custom")}}
    <div class="shop-item-drop">
      <div class="shop-item-drop-toolbar">
        <p class="hint"><i class="fa-solid fa-hand-pointer"></i> {{localize "CRUCIBLE_SHOP.DropHint"}}</p>
        <button type="button" class="add-from-compendium" data-action="addFromCompendium">
          <i class="fa-solid fa-boxes-stacked"></i> {{localize "CRUCIBLE_SHOP.ImportButton"}}
        </button>
        <button type="button" class="randomize-items" data-action="randomizeItems">
          <i class="fa-solid fa-dice"></i> {{localize "CRUCIBLE_SHOP.RandomizeItems"}}
        </button>
      </div>
      <ol class="shop-manager-item-list">
        {{#each items as |item|}}
        <li class="shop-manager-item {{#if item.missing}}missing{{/if}}" data-uuid="{{item.uuid}}">
          <img src="{{item.img}}" alt="{{item.name}}"/>
          <span class="item-name">{{item.name}}</span>
          {{#unless item.missing}}
          <crucible-currency class="item-price-input" data-uuid="{{item.uuid}}" value="{{item.price}}"
                              data-tooltip="{{localize 'CRUCIBLE_SHOP.ItemPrice'}}"></crucible-currency>
          {{/unless}}
          <a class="remove-item" data-action="removeItem" data-uuid="{{item.uuid}}">
            <i class="fa-solid fa-xmark"></i>
          </a>
        </li>
        {{else}}
        <li class="empty">{{localize "CRUCIBLE_SHOP.NoCustomItems"}}</li>
        {{/each}}
      </ol>
    </div>
    {{else}}
    <p class="hint">{{localize "CRUCIBLE_SHOP.DefaultModeHint"}}</p>
    {{/if}}

    <div class="shop-invite-panel">
      <h3>{{localize "CRUCIBLE_SHOP.InvitePlayers"}}</h3>
      <button type="button" class="invite-public" data-action="invitePublic">
        <i class="fa-solid fa-bullhorn"></i> {{localize "CRUCIBLE_SHOP.InvitePublic"}}
      </button>
      {{#unless noUsers}}
      <ol class="user-checklist">
        {{#each users as |user|}}
        <li>
          <label>
            <input type="checkbox" name="inviteUser" value="{{user.id}}"/>
            {{user.name}}
            {{#if user.active}}<i class="fa-solid fa-circle online" data-tooltip="{{localize 'CRUCIBLE_SHOP.Online'}}"></i>{{/if}}
          </label>
        </li>
        {{/each}}
      </ol>
      <button type="button" class="invite-whisper" data-action="inviteWhisper">
        <i class="fa-solid fa-user"></i> {{localize "CRUCIBLE_SHOP.InviteWhisper"}}
      </button>
      {{/unless}}
    </div>

    {{#if showPendingPanel}}
    <div class="pending-requests-panel">
      <h3>{{localize "CRUCIBLE_SHOP.PendingRequests"}}</h3>
      {{#if noPendingRequests}}
      <p class="hint">{{localize "CRUCIBLE_SHOP.NoPendingRequests"}}</p>
      {{else}}
      <ol class="pending-requests-list">
        {{#each pendingRequests as |req|}}
        <li class="pending-request-entry" data-message-id="{{req.messageId}}">
          <div class="pending-request-summary">
            <i class="fa-solid {{#if req.isBuy}}fa-cart-shopping{{else}}fa-hand-holding-dollar{{/if}}"></i>
            <span>
              {{#if req.isBuy}}
              {{localize "CRUCIBLE_SHOP.PendingBuySummary" user=req.userName actor=req.actorName total=req.total}}
              {{else}}
              {{localize "CRUCIBLE_SHOP.PendingSellSummary" user=req.userName actor=req.actorName total=req.total}}
              {{/if}}
            </span>
          </div>
          <ul class="pending-request-items">
            {{#each req.entries as |entry|}}
            <li>{{entry.name}} <span class="qty">x{{entry.quantity}}</span></li>
            {{/each}}
          </ul>
          <div class="pending-request-actions">
            <button type="button" class="deny" data-action="denyRequest">
              <i class="fa-solid fa-xmark"></i> {{localize "CRUCIBLE_SHOP.Deny"}}
            </button>
            <button type="button" class="approve" data-action="approveRequest">
              <i class="fa-solid fa-check"></i> {{localize "CRUCIBLE_SHOP.Approve"}}
            </button>
          </div>
        </li>
        {{/each}}
      </ol>
      {{/if}}
    </div>
    {{/if}}

    {{/if}}
  </section>
</div>
